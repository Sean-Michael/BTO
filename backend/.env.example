# Copy to .env and fill in. All vars are prefixed BTO_.

# Path to the built frontend (dist/). Leave unset in dev — Vite serves the UI.
# BTO_STATIC_DIR=/app/static

# Allowed CORS origins in dev (JSON list).
# BTO_CORS_ORIGINS=["http://localhost:5173"]

# Seconds to cache NOAA prediction responses in-memory.
# BTO_CACHE_TTL=900
